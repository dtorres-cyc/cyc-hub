# ── Base de datos (Railway provee DATABASE_URL automáticamente con el plugin PostgreSQL) ──
DATABASE_URL="postgresql://cyc_user:cyc_password@localhost:5432/cyc_tasks"

# ── JWT ──
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Servidor ──
PORT=3001
NODE_ENV=development

# ── Upload de archivos ──
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=20971520

# ── CORS: orígenes permitidos separados por coma (Railway frontend URL) ──
# ALLOWED_ORIGINS=https://cyc-tasks-client.up.railway.app,https://tudominio.cl

# ── Cliente Vite (solo necesaria en build de producción) ──
# VITE_API_URL=https://cyc-tasks-server.up.railway.app
