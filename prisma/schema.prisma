generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id             Int       @id @default(autoincrement())
  name           String
  rut            String?
  industry       String?
  segment        String?
  size           String?
  owner          String?
  totalInvoiced  Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  contacts       Contact[]
  opportunities  Opportunity[]
}

model Contact {
  id             Int       @id @default(autoincrement())
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  role           String?
  status         String    @default("Lead") // Lead, MQL, SQL, Cliente
  lastContacted  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  companyId      Int?
  company        Company?  @relation(fields: [companyId], references: [id])

  opportunities  Opportunity[]
}

model Opportunity {
  id             Int       @id @default(autoincrement())
  name           String
  amount         Float     @default(0)
  stage          String    @default("Prospecto") // Prospecto, Calificado, Cotización Enviada, Negociación, Ganado, Perdido
  probability    Int       @default(10)
  priority       String    @default("Media") // Baja, Media, Alta
  expectedClose  DateTime?
  businessType   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  companyId      Int?
  company        Company?  @relation(fields: [companyId], references: [id])

  contactId      Int?
  contact        Contact?  @relation(fields: [contactId], references: [id])

  comments       Comment[]
  attachments    Attachment[]
  quotes         QuoteRecord[]
}

model WeeklyReport {
  id                  Int      @id @default(autoincrement())
  createdAt           DateTime @default(now())
  
  // Snapshots
  rentedEquipments    Int      @default(0)
  workshopEquipments  Int      @default(0)
  monthlyBilled       Float    @default(0)
  pipelineValue       Float    @default(0)
  pipelineClosedValue Float    @default(0)

  // Analysis texts
  analysisRental      String?
  analysisWorkshop    String?
  analysisBilling     String?
  analysisPipeline    String?
}

model Comment {
  id             Int       @id @default(autoincrement())
  text           String
  createdAt      DateTime  @default(now())
  
  opportunityId  Int
  opportunity    Opportunity @relation(fields: [opportunityId], references: [id])
}

model Attachment {
  id             Int       @id @default(autoincrement())
  filename       String
  path           String
  createdAt      DateTime  @default(now())
  
  opportunityId  Int
  opportunity    Opportunity @relation(fields: [opportunityId], references: [id])
}

model QuoteRecord {
  id             Int       @id @default(autoincrement())
  quoteNumber    Int
  amount         Float
  pdfPath        String?
  driveUrl       String?
  createdAt      DateTime  @default(now())

  opportunityId  Int
  opportunity    Opportunity @relation(fields: [opportunityId], references: [id])
}

model FlotaEquipo {
  id              Int      @id @default(autoincrement())
  tipoMaquinaria  String
  marca           String?
  modelo          String?
  anio            String?
  horometro       String?
  detalle         String?
  tarifa          String?
  imagenUrl       String?
  numeroInterno   String?
  activo          Boolean  @default(true)
  notionId        String?  @unique  // Para evitar duplicados en importación
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Gestión de Arriendo ──────────────────────────────────────────────────────

model Contrato {
  id              Int       @id @default(autoincrement())
  numeroContrato  String
  cliente         String
  equipos         String?   // Legacy fallback JSON
  fechaInicio     DateTime
  fechaTermino    DateTime
  activo          Boolean   @default(true)

  // Checklist Documentación
  docOC           Boolean   @default(false)
  docContrato     Boolean   @default(false)
  docActaEntrega  Boolean   @default(false)

  notas           String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contratoEquipos ContratoEquipo[]
  edps            EDP[]
  danosMermas     DanosMerma[]
}

model ContratoEquipo {
  id               Int       @id @default(autoincrement())
  contratoId       Int
  contrato         Contrato  @relation(fields: [contratoId], references: [id])

  equipoId         String    // N° Interno
  equipoTipo       String?   // Tolva, Aljibe, etc.

  // Entrega
  fechaEntrega     DateTime?
  horometroEntrega Float?

  // Cobro
  tipoCobro        String    @default("fijo") // "fijo" | "hora"
  moneda           String    @default("CLP")  // "CLP" | "UF"
  valorFijo        Float?    // Si tipoCobro == "fijo"
  tarifaHora       Float?    // Si tipoCobro == "hora"
  horasMinimas     Float?    // Si tipoCobro == "hora"
  valorHoraExtra   Float?    // Si tipoCobro == "hora"

  // Baja individual del equipo
  activo           Boolean   @default(true)
  fechaBaja        DateTime?
  motivoBaja       String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  danosMermas      DanosMerma[]
  edpDetalles      EDPDetalleEquipo[]
}


model EDP {
  id              Int       @id @default(autoincrement())
  contratoId      Int
  contrato        Contrato  @relation(fields: [contratoId], references: [id])

  mes             Int?      // 1-12 (legacy)
  anio            Int?      // (legacy)
  periodo         String?   // "Mayo 2026" (legacy)
  
  mesConsumo      String    @default("") // "2024-04"
  estado          String    @default("Solicitud") // Solicitud, Enviado, Negociación, Cerrado, Facturado
  valorUfCierre   Float?

  subtotal        Float     @default(0)
  iva             Float     @default(0)
  total           Float     @default(0)

  // Etapas de control
  etapa           Int       @default(1)
  horometroSolicitado DateTime?
  horometroRecibido   DateTime?
  edpEnviado          DateTime?
  negociacionInicio   DateTime?
  facturado           DateTime?

  montoEdp        Float?
  observaciones   String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  detalles        EDPDetalleEquipo[]
  adicionales     EDPAdicional[]
}

model EDPDetalleEquipo {
  id                 Int       @id @default(autoincrement())
  edpId              Int
  edp                EDP       @relation(fields: [edpId], references: [id])
  contratoEquipoId   Int
  contratoEquipo     ContratoEquipo @relation(fields: [contratoEquipoId], references: [id])

  diasTrabajados     Int?
  horometroCierre    Float?
  horasExtras        Float?
  montoGenerado      Float     @default(0)

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model EDPAdicional {
  id              Int       @id @default(autoincrement())
  edpId           Int
  edp             EDP       @relation(fields: [edpId], references: [id])

  tipo            String    // "Cargo" | "Descuento"
  concepto        String
  monto           Float

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model DanosMerma {
  id               Int            @id @default(autoincrement())
  contratoId       Int?
  contrato         Contrato?      @relation(fields: [contratoId], references: [id])
  contratoEquipoId Int?
  contratoEquipo   ContratoEquipo? @relation(fields: [contratoEquipoId], references: [id])

  equipoId         String
  equipoDesc       String?
  cliente          String?

  // Etapas: 1=Recepcionar | 2=Levantamiento | 3=Enviar informe | 4=Negociación | 5=Facturado | 6=Pagado
  etapa            Int       @default(1)

  recepcionFecha     DateTime?
  recepcionFotos     String?
  levantamientoFecha DateTime?
  informeEnviado     DateTime?
  negociacionInicio  DateTime?
  facturadoFecha     DateTime?
  pagadoFecha        DateTime?

  montoDano        Float?
  montoFacturado   Float?
  observaciones    String?
  pdfLink          String?

  activo           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}
