generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id             Int       @id @default(autoincrement())
  name           String
  rut            String?
  industry       String?
  segment        String?
  size           String?
  owner          String?
  totalInvoiced  Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  contacts       Contact[]
  opportunities  Opportunity[]
}

model Contact {
  id             Int       @id @default(autoincrement())
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  role           String?
  status         String    @default("Lead") // Lead, MQL, SQL, Cliente
  lastContacted  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  companyId      Int?
  company        Company?  @relation(fields: [companyId], references: [id])

  opportunities  Opportunity[]
}

model Opportunity {
  id             Int       @id @default(autoincrement())
  name           String
  amount         Float     @default(0)
  stage          String    @default("Prospecto") // Prospecto, Calificado, Cotización Enviada, Negociación, Ganado, Perdido
  probability    Int       @default(10)
  priority       String    @default("Media") // Baja, Media, Alta
  expectedClose  DateTime?
  businessType   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  companyId      Int?
  company        Company?  @relation(fields: [companyId], references: [id])

  contactId      Int?
  contact        Contact?  @relation(fields: [contactId], references: [id])

  comments       Comment[]
  attachments    Attachment[]
  quotes         QuoteRecord[]
}

model WeeklyReport {
  id                  Int      @id @default(autoincrement())
  createdAt           DateTime @default(now())
  
  // Snapshots
  rentedEquipments    Int      @default(0)
  workshopEquipments  Int      @default(0)
  monthlyBilled       Float    @default(0)
  pipelineValue       Float    @default(0)
  pipelineClosedValue Float    @default(0)

  // Analysis texts
  analysisRental      String?
  analysisWorkshop    String?
  analysisBilling     String?
  analysisPipeline    String?
}

model Comment {
  id             Int       @id @default(autoincrement())
  text           String
  createdAt      DateTime  @default(now())
  
  opportunityId  Int
  opportunity    Opportunity @relation(fields: [opportunityId], references: [id])
}

model Attachment {
  id             Int       @id @default(autoincrement())
  filename       String
  path           String
  createdAt      DateTime  @default(now())
  
  opportunityId  Int
  opportunity    Opportunity @relation(fields: [opportunityId], references: [id])
}

model QuoteRecord {
  id             Int       @id @default(autoincrement())
  quoteNumber    Int
  amount         Float
  pdfPath        String?
  driveUrl       String?
  createdAt      DateTime  @default(now())

  opportunityId  Int
  opportunity    Opportunity @relation(fields: [opportunityId], references: [id])
}
